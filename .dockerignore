# Everything the Dockerfile doesn't COPY is dead weight in the build context —
# it rebuilds deps/assets inside the image from source.
/_build/
/deps/
/.git/
/.elixir_ls/
/.lexical/
/cover/
/doc/
/tmp/
/.fetch
erl_crash.dump
*.ez
uitstalling-*.tar
npm-debug.log
/assets/node_modules/

# Built assets are produced by `mix assets.deploy` inside the builder
/priv/static/assets/
/priv/static/cache_manifest.json

# Dev-only local asset uploads (prod uses Tigris)
/priv/uploads/

# Editor/session droppings
.DS_Store
/.claude/
/docs/
